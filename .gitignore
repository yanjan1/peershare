# =========================
# Recursive ignores
# =========================

# Ignore ANY nested node_modules recursively
**/node_modules/

# Ignore nested dist/build folders
**/dist/
**/build/

# Ignore nested coverage folders
**/coverage/

# Ignore nested cache folders
**/.cache/

# Ignore nested env files
**/.env
**/.env.*

# Ignore nested logs
**/*.log

# =========================
# Optional binary junk
# =========================
*.exe
*.dll
*.so
*.dylib

#================
# rust stuff
#================
# --- Rust Backend ---
# The target directory contains all compiled binary artifacts
/src-tauri/target/
# Cargo-generated files that shouldn't be tracked (unless it's a binary crate)
# Note: Keep Cargo.lock for apps to ensure deterministic builds
# /src-tauri/Cargo.lock 

